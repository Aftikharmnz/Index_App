ice_monthly_vwap
ice_monthly_vwap <- ice_normalized_final %>%
filter(
index_group == "SW",
exec_date >= trade_cycle_start,
exec_date <= trade_cycle_end
) %>%
group_by(
broker,
period_delivery_month,
trade_cycle_start,
trade_cycle_end,
index_group
) %>%
summarise(
trade_count = n_distinct(trade_id),
total_volume_m3 = sum(qty_m3, na.rm = TRUE),
vwap_price = sum(price * qty_m3, na.rm = TRUE) / sum(qty_m3, na.rm = TRUE),
# These are only diagnostics, not grouping logic
first_actual_trade_date = min(exec_date, na.rm = TRUE),
last_actual_trade_date = max(exec_date, na.rm = TRUE),
min_price = min(price, na.rm = TRUE),
max_price = max(price, na.rm = TRUE),
avg_price_simple = mean(price, na.rm = TRUE),
.groups = "drop"
) %>%
arrange(period_delivery_month, index_group)
ice_monthly_vwap
# =============================================================================
# ICE SW VWAP only
# =============================================================================
library(dplyr)
library(stringr)
library(lubridate)
ice_sw_vwap_input <- ice_normalized_final %>%
mutate(
index_group_clean = str_to_upper(str_squish(as.character(index_group))),
class_clean = str_to_upper(str_squish(as.character(index_trade_financial))),
swap_clean = str_to_upper(str_squish(as.character(swap))),
price_num = as.numeric(price),
qty_m3_month = as.numeric(qty_m3)
) %>%
filter(
index_group_clean == "SW",
class_clean == "TRADE",
# ICE rules have blank swap for outright rows.
# Keep blanks as outright-equivalent.
is.na(swap_clean) | swap_clean == "" | swap_clean == "OUTRIGHT",
inside_trade_cycle == TRUE,
# ICE equivalent of In Index? is the matched classification rule.
# Since ICE_Rules has Y_N blank, do not use y_n == "Y" here.
!is.na(index_group),
!is.na(key_id),
!is.na(price_num),
!is.na(qty_m3_month),
qty_m3_month > 0
)
ice_sw_vwap <- ice_sw_vwap_input %>%
group_by(
strip,
period_delivery_month,
trade_cycle_start,
trade_cycle_end,
index_group
) %>%
summarise(
trade_count = n(),
total_volume_m3_per_month = sum(qty_m3_month, na.rm = TRUE),
vwap = sum(price_num * qty_m3_month, na.rm = TRUE) /
sum(qty_m3_month, na.rm = TRUE),
min_price = min(price_num, na.rm = TRUE),
max_price = max(price_num, na.rm = TRUE),
.groups = "drop"
) %>%
arrange(period_delivery_month)
View(ice_normalized_final)
